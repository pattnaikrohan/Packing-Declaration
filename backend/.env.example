# Database — SQLite (no server needed, file-based)
DATABASE_URL=sqlite:///./data/pkd.db

# Power Automate Webhooks (leave blank to use mock/log mode)
POWER_AUTOMATE_PROCEED_URL=
POWER_AUTOMATE_REJECT_URL=

# HMAC secret for webhook signing
WEBHOOK_SECRET=change-this-to-a-random-secret

# Tesseract OCR binary path
# Windows example: C:/Program Files/Tesseract-OCR/tesseract.exe
# Linux/Azure: /usr/bin/tesseract (auto from PATH)
TESSERACT_CMD=tesseract

# Path to store trained ML model files
MODEL_STORE_PATH=./app/models_store

# Minimum corpus records before ML scoring activates
MIN_TRAINING_RECORDS=20

# APScheduler cron for auto-retrain (Sunday 02:00)
RETRAIN_CRON=0 2 * * 0

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
