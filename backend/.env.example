# ── Database ──
# SQLite (file-based, no server needed)
DATABASE_URL=sqlite:///./data/pkd.db

# ── Power Automate Webhooks ──
# Leave blank to run in mock/log mode
POWER_AUTOMATE_URL=
POWER_AUTOMATE_PROCEED_URL=
POWER_AUTOMATE_REJECT_URL=

# ── HMAC secret for webhook signing ──
WEBHOOK_SECRET=change-this-to-a-random-secret

# ── Tesseract OCR ──
# Docker/Linux: /usr/bin/tesseract (auto)
# Windows local: C:/Program Files/Tesseract-OCR/tesseract.exe
TESSERACT_CMD=tesseract

# ── ML Model Store ──
MODEL_STORE_PATH=./app/models_store
MIN_TRAINING_RECORDS=20

# ── Auto-Retrain Schedule (Sunday 02:00) ──
RETRAIN_CRON=0 2 * * 0

# ── CORS ──
# Comma-separated allowed origins
# For production, set to your Azure Static Web App URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Azure Blob Storage ──
# Option A: Connection String (local dev)
AZURE_STORAGE_CONNECTION_STRING=

# Option B: SAS URL (production / Azure App Service)
# Format: https://<account>.blob.core.windows.net/<container>?<sas-token>
AZURE_STORAGE_SAS_URL=

AZURE_CONTAINER_NAME=packing-declaration
AZURE_FOLDER_NAME=
